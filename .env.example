# ==========================================
# GEMINI API KEY (for Gemini AI API calls)
# ==========================================
GEMINI_API_KEY="your_gemini_api_key_here"

# ==========================================
# APP URL / PORTS
# ==========================================
APP_URL="https://fixdev.web.id"
APP_PORT="3000"
DEV_PORT="8083"

# ==========================================
# SUPABASE CONFIGURATION
# ==========================================
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your_supabase_anon_key"

# Server-only. Never expose this with VITE_ prefix.
SUPABASE_SERVICE_ROLE_KEY="your_supabase_service_role_key"
SUPABASE_DB_URL="postgresql://postgres:password@host:5432/postgres"
SUPABASE_DB_POOL_MAX="10"

# Required for /api/supabase/* and admin maintenance endpoints.
# Send via x-supabase-admin-token.
# Generate via: openssl rand -hex 32
SUPABASE_ADMIN_TOKEN="generate-a-random-secret-token-here"

# ==========================================
# API V1 DEV TOKENS
# ==========================================
# Dev fallback tokens are disabled unless this is true.
# Keep false in production. Real tokens live in api_tokens table.
ALLOW_DEV_API_TOKENS="false"

# ==========================================
# RATE LIMITING
# ==========================================
RATE_LIMIT_WINDOW_MS="60000"
RATE_LIMIT_MAX="2000"
ADMIN_RATE_LIMIT_WINDOW_MS="60000"
ADMIN_RATE_LIMIT_MAX="500"

# ==========================================
# WHATSAPP WORKER
# ==========================================
# Safe default: worker dry-runs unless this is explicitly false.
WHATSAPP_WORKER_DRY_RUN="true"
WHATSAPP_WORKER_BATCH_SIZE="10"
WHATSAPP_WORKER_MAX_RETRIES="3"
WHATSAPP_WORKER_RETRY_DELAY_MS="1000"
WHATSAPP_WORKER_INTERVAL_MS="60000"
FONNTE_API_URL="https://api.fonnte.com/send"

# ==========================================
# MIDTRANS PAYMENT GATEWAY
# ==========================================
# Server-side only. Never expose with VITE_ prefix.
MIDTRANS_SERVER_KEY="your_midtrans_server_key"
MIDTRANS_CLIENT_KEY="your_midtrans_client_key"
MIDTRANS_MERCHANT_ID="your_midtrans_merchant_id"
MIDTRANS_IS_PRODUCTION="false"

# ==========================================
# SERVER / LOGGING
# ==========================================
# NODE_ENV: "development" = Vite middleware + HMR; "production" = serve static dist/
# Production deployments (systemd/PM2) override this to "production".
# For local dev, keep "development" so npm run dev enables Vite HMR.
NODE_ENV="production"
LOG_LEVEL="info"
DISABLE_HMR="true"

# ==========================================
# EMAIL CONFIGURATION (for nodemailer)
# ==========================================
# Email host (smtp.gmail.com, smtp.mailgun.org, dll)
EMAIL_HOST=smtp.gmail.com
# Email port (587 for TLS, 465 for SSL)
EMAIL_PORT=587
# Email username (your email address)
EMAIL_USER=your@email.com
# Email password (app password for Gmail)
EMAIL_PASS=your-app-password
# From email address
EMAIL_FROM=noreply@fixdev.my.id

# ==========================================
# CRON JOB SCHEDULE
# ==========================================
# Cron expression untuk check trial expiry (default: daily at 00:00)
# Format: minute hour day month weekday
TRIAL_EXPIRY_CHECK_CRON="0 0 * * *"

# ==========================================
# TELEGRAM/WHATSAPP ALERTS
# ==========================================
# Alert when >10 tenants expired
EXPIRED_TENANT_ALERT_THRESHOLD=10
